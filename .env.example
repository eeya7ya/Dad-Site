# ── Rose Lens environment ────────────────────────────────────────────────
# Copy to `.env.local` and fill in. Never commit the filled-in file.

# Neon serverless Postgres — use the POOLED connection string
# (Neon dashboard → Connection Details → "Pooled connection").
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Anthropic API key for the "Iris" concierge (model: claude-haiku-4-5)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
